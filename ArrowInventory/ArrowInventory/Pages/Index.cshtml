@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="display-4">Welcome to Arrow labs Inventory System</h1>
</div>


<div class="card bg-body-tertiary border-secondary mb-4">
    <div class="card-body">
        <div class="row d-flex justify-content-center">
            <div class="col-md-3">
                <div class="card bg-body-tertiary border-secondary text-body">
                    <div class="card-body">
                        <h6 class="text-center text-secondary">
                            Total Devices
                        </h6>
                        <h2 class="text-center stat-number stat-card-devices">@Model.Devices.Count</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-body-tertiary border-secondary text-body">
                    <div class="card-body">
                        <h6 class="text-center text-secondary">
                            Total Virtual Machines
                        </h6>
                        <h2 class="text-center stat-number stat-card-vms">@Model.Devices.Count(d => d.isVirtualMachine == true)</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-body-tertiary border-secondary text-body">
                    <div class="card-body">
                        <h6 class="text-center text-secondary">
                            Total Physical Machines
                        </h6>
                        <h2 class="text-center stat-number stat-card-physical">@Model.Devices.Count(d => d.isVirtualMachine == false)</h2>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>