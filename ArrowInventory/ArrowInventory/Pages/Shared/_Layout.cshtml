<!DOCTYPE html>
<html lang="en"
    data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ArrowInventory</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ArrowInventory.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" />
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Slab:wght@100..900&display=swap" rel="stylesheet">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark border-bottom border-secondary box-shadow mb-5"
             style="background: linear-gradient(135deg, rgba(33, 37, 41, 0.85), rgba(50, 55, 60, 0.75)) !important; backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(8px); border-bottom: 1px solid rgba(255,255,255,0.1) !important;">

            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">
                    <img src="https://arwlabazblob.blob.core.windows.net/intune-assets/ArrowLabs-Icon.png"
                         alt="ArrowLabs Logo"
                         width="50"
                         height="50"
                         class="me-2"
                         />                
                    
                    ArrowInventory</a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <!--Home Page-->
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <!--Add Device Page-->
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-page="/AddDevices">Add</a>
                        </li>
                        <!--Manage Devices Page-->
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-page="/ManageDevices">Manage</a>
                        </li>
                        <!--Admin Page-->
                        @if(User.IsInRole("Admin"))
                            {
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-area="" asp-page="/Admin">Admin</a>
                            </li>
                                
                            }
                    </ul>
                </div>
            </div>

            @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="sidebar-link px-2 py-2 text-truncate">
                        <span class="material-symbols-outlined sidebar-icon">account_circle</span>
                        <span class="sidebar-text text-white">@User.Identity.Name</span>
                    </div>
                }

        </nav>
    </header>
    <div class="container">
        <main role="main" class="py-4">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container d-flex justify-content-between align-items-center">
            <span>
                &copy; 2026 - ArrowStudio - Support@ArrowStudio.co.uk <a asp-area="" asp-page="/Privacy">Privacy</a>
            </span>
                <button class="btn btn-lg" id="themeToggle">
                    <span class="material-symbols-outlined" id="themeIcon">
                        toggle_off
                    </span>
                </button>
        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)



    <script>
        const toggleBtn = document.getElementById('themeToggle');
        const themeIcon = document.getElementById('themeIcon');

        toggleBtn.addEventListener('click', () => {
            const html = document.documentElement;
            const current = html.getAttribute('data-bs-theme');
            const next = current == 'dark' ? 'light' : 'dark';
            html.setAttribute('data-bs-theme', next);
            themeIcon.textContent = next == 'dark' ? 'toggle_on' : 'toggle_off';
            localStorage.setItem('theme', next);
        });

        const saved = localStorage.getItem('theme');
        if(saved){
            document.documentElement.setAttribute('data-bs-theme', saved);
                themeIcon.textContent = saved == 'dark' ? 'toggle_on' : 'toggle_off';
        }
    </script>


</body>
</html>
