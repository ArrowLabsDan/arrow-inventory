@page
@model ArrowInventory.Pages.ResetPasswordModel
@{
    Layout = "_LayoutSidebar";
    ViewData["Title"] = "Reset Password";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-0">Reset Password</h1>
        <small class="text-secondary">Change your account password</small>
    </div>
</div>

@if (TempData["StatusMessage"] != null)
{
    <div class="alert alert-@TempData["StatusType"]">
        @TempData["StatusMessage"]
    </div>
}

<div class="card bg-body-tertiary border-secondary mb-4">
    <div class="d-flex justify-content-center">
        <div class="col-md-6">
            <div class="card-body">
                <form method="post">
                    <div class="mb-3">
                        <label>Current Password <span class="text-danger">*</span></label>
                        <input asp-for="CurrentPassword" type="password" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label>New Password <span class="text-danger">*</span></label>
                        <input asp-for="NewPassword" type="password" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label>Confirm Password <span class="text-danger">*</span></label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control" />
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Change Password</button>
                        <a asp-page="/Index" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
