@page
@model ArrowInventory.Pages.ManageUserModel
@{
    Layout = "_LayoutSidebar";
    ViewData["Title"] = "User Admin";
}
<div class="d-flex justify-content-between align-items-center mb-4">

    <div>
        <h1 class="mb-0">ArrowLabs Inventory</h1>
        <small class="text-secondary">
            ArrowLabs User Management
        </small>
    </div>

</div>
@if (TempData["StatusMessage"] != null)
{
    <div class="alert alert-@TempData["StatusType"]">
        @TempData["StatusMessage"]

    </div>
}

<div class="card bg-body-tertiary border-secondary mb-4">
    <div class="d-flex justify-content-center">
        <div class="col-md-6">

            <div class="card-body">

                <div class="text-center">
                    <h3>Create Users</h3>
                </div>

                <form method="post" asp-page-handler="CreateUser">

                    <div class="mb-3">
                        <label>Username</label>
                        <input asp-for="NewUsername" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label>DisplayName</label>
                        <input asp-for="NewDisplayName" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label>Email</label>
                        <input asp-for="NewEmail" class="form-control" type="email" />
                    </div>

                    <div class="mb-3">
                        <label>Password</label>
                        <input asp-for="NewPassword" type="password" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label>Role</label>
                        <select asp-for="NewRole" class="form-control">
                            <option>Admin</option>
                            <option>Read & Write</option>
                            <option>Read Only</option>
                        </select>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        Create User
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="text-center">
    <h3>Manage Users</h3>
</div>

<div class="mb-3">
    <table class="table table-bordered table-hover text-center align-middle">
        <thead>
            <tr>
                <th>Username</th>
                <th>DisplayName</th>
                <th>UserID</th>
                <th>Email</th>
                <th>Role</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var user in Model.Users)
            {
                <tr>
                    <td>@user.UserName</td>
                    <td>@user.DisplayName</td>
                    <td>@user.Id</td>
                    <td>@user.Email</td>
                    <td>@string.Join(",", Model.UserRoles.GetValueOrDefault(user.Id, new List<string>()))</td>
                    <td>
                        <form method="post" asp-page-handler="DeleteUser">
                            <input type="hidden" name="userID" value="@user.Id" />
                            <button type="submit" class="dropdown-item text-danger">
                                <span class="material-symbols-outlined">delete</span>
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>